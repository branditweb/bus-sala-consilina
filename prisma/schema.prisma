generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bus {
  id                  Int      @id @default(autoincrement())
  compagnia           String
  orario_partenza     DateTime
  destinazione        String
  sito_web_compagnia  String?
  contatti            String?
}

model Company {
  id         Int      @id @default(autoincrement())
  nome       String   @unique
  slug       String   @unique
  sito_web   String?
  telefono   String?
  email      String?
  attiva     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TrendingDestination {
  id          Int      @id @default(autoincrement())
  city        String
  description String
  price_from  String?
  rating      String?
  duration    String?
  image_url   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
